{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "description": { "type": "string", "description": "Project description" },
        "image": { "type": "string", "description": "Image URL" },
        "technologies": { "type": "array", "items": { "type": "string" }, "description": "List of technologies used" },
        "github": { "type": "string", "description": "GitHub repository link" },
        "demo": { "type": "string", "description": "Live demo link" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "description", "image"]
    },
    "Message": {
      "title": "Message",
      "description": "A contact form submission",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "description": "Sender email" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" },
        "status": { "type": "string", "enum": ["read", "unread"], "description": "Read status" }
      },
      "required": ["name", "email", "message"]
    },
    "WebsiteContent": {
      "title": "Website Content",
      "description": "Global website content settings",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "title": { "type": "string" },
            "subtitle": { "type": "string" }
          }
        },
        "about": {
          "type": "object",
          "properties": {
            "content": { "type": "string" },
            "experience": { "type": "string" },
            "completed": { "type": "string" }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "location": { "type": "string" },
            "github": { "type": "string" },
            "linkedin": { "type": "string" },
            "telegram": { "type": "string" }
          }
        },
        "seo": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "VisitorStats": {
      "title": "Visitor Stats",
      "description": "Daily visitor counts",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "count": { "type": "number" }
      }
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "messages": {
      "schema": "Message",
      "description": "Collection of contact messages"
    },
    "settings": {
      "schema": "WebsiteContent",
      "description": "Global website settings (single document: 'global')"
    },
    "stats": {
      "schema": "VisitorStats",
      "description": "Daily visitor statistics"
    }
  }
}
